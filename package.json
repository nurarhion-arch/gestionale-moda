{
  "name": "gestionale-logistica-moda",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c green,cyan \"npm:dev --workspace server\" \"npm:dev --workspace client\"",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
